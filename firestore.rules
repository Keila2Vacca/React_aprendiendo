rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Sesiones de usuario
    match /userSessions/{sessionId} {
      allow read, write, create: if request.auth != null;
    }
    
    // Datos de usuario (Soporta /users o /userData según uses en tu código)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /userData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Tickets / Pasajes
    match /tickets/{ticketId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Clientes (Permite leer y escribir si estás logueado y guardas tu propio userId)
    match /clients/{clientId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Rutas y viajes (Lectura global para todos los logueados)
    match /rutas/{rutaId} {
      allow read: if request.auth != null;
    }
    match /viajes/{viajeId} {
      allow read: if request.auth != null;
    }
  }
}